# capylink backend environment template
# Copy to .env on the droplet and fill in real values. Never commit .env.
#
# CAPYLINK_DB_URL and QUARKUS_PROFILE are NOT here on purpose — they are
# non-sensitive and hardcoded in docker-compose.yml (the container reaches
# postgres at jdbc:postgresql://postgres:5432/capylink over capypad-net).

# PostgreSQL (separate `capylink` database/user on the shared capypad postgres)
CAPYLINK_DB_USER=<postgres-username>
CAPYLINK_DB_PASSWORD=<postgres-password>

# App settings
CAPYLINK_BASE_URL=<public-base-url>
