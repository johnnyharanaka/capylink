# Base URL of the backend API.
#
# Production (GitHub Pages build): the SPA is on link.eiji.dev and the API is
# on a different origin, so this must point at the backend:
#   VITE_API_URL=https://api.eiji.dev
# The deploy workflow writes this into .env.production automatically.
#
# Dev: leave this unset — the Vite dev server proxies /api to localhost:8080
# (same origin), so no VITE_API_URL is needed.
VITE_API_URL=https://api.eiji.dev
